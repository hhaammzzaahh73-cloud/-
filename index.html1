<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="أبطال السيرة">
<meta name="theme-color" content="#1A3A5C">
<title>أبطال السيرة</title>
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icon-192.png">
<link rel="icon" type="image/png" sizes="192x192" href="icon-192.png">
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=Amiri:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #D4A847;
    --gold-light: #F0CC6A;
    --gold-dark: #A07830;
    --green: #2D6A4F;
    --green-light: #40916C;
    --green-mid: #52B788;
    --cream: #FDF6E3;
    --cream-dark: #F5E6C4;
    --brown: #5C3D1E;
    --brown-light: #7D5A3C;
    --sky: #1A3A5C;
    --sky-light: #2C5F8A;
    --white: #FFFDF7;
    --star-yellow: #FFD700;
    --error: #C0392B;
    --success: #27AE60;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Tajawal', sans-serif;
    background: var(--sky);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  /* Stars background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: 
      radial-gradient(ellipse at 20% 20%, rgba(212,168,71,0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 80%, rgba(45,106,79,0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 0%, rgba(44,95,138,0.3) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  .stars {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .star {
    position: absolute;
    background: white;
    border-radius: 50%;
    animation: twinkle var(--d, 3s) ease-in-out infinite alternate;
    opacity: 0.6;
  }

  @keyframes twinkle {
    from { opacity: 0.2; transform: scale(0.8); }
    to { opacity: 0.9; transform: scale(1.2); }
  }

  /* Screens */
  .screen {
    position: fixed;
    inset: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 10;
    padding: 20px;
    overflow-y: auto;
  }

  .screen.active {
    display: flex;
  }

  /* HOME SCREEN */
  #homeScreen {
    background: linear-gradient(160deg, #0D2137 0%, #1A3A5C 40%, #0D3320 100%);
  }

  .home-container {
    text-align: center;
    max-width: 400px;
    width: 100%;
    animation: fadeInUp 0.8s ease forwards;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .moon-icon {
    width: 90px;
    height: 90px;
    margin: 0 auto 16px;
    position: relative;
    filter: drop-shadow(0 0 20px rgba(212,168,71,0.5));
    animation: float 4s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .app-title {
    font-family: 'Amiri', serif;
    font-size: 3.2rem;
    font-weight: 700;
    color: var(--gold-light);
    text-shadow: 0 0 30px rgba(212,168,71,0.4);
    line-height: 1.1;
    margin-bottom: 6px;
  }

  .app-subtitle {
    font-size: 1rem;
    color: rgba(255,255,255,0.65);
    margin-bottom: 40px;
    font-weight: 400;
    letter-spacing: 0.05em;
  }

  .btn-primary {
    display: block;
    width: 100%;
    padding: 16px 24px;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
    color: var(--brown);
    font-family: 'Tajawal', sans-serif;
    font-size: 1.2rem;
    font-weight: 800;
    border: none;
    border-radius: 16px;
    cursor: pointer;
    margin-bottom: 14px;
    box-shadow: 0 6px 20px rgba(212,168,71,0.35), 0 2px 8px rgba(0,0,0,0.2);
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .btn-primary::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.4s;
  }

  .btn-primary:hover::after { left: 100%; }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(212,168,71,0.45);
  }

  .btn-primary:active { transform: translateY(0); }

  .btn-secondary {
    display: block;
    width: 100%;
    padding: 14px 24px;
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.85);
    font-family: 'Tajawal', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    border: 1.5px solid rgba(255,255,255,0.2);
    border-radius: 14px;
    cursor: pointer;
    margin-bottom: 12px;
    transition: all 0.2s ease;
    backdrop-filter: blur(8px);
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.4);
    transform: translateY(-1px);
  }

  .version-badge {
    margin-top: 28px;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
  }

  /* LEVELS SCREEN */
  #levelsScreen {
    background: linear-gradient(160deg, #0D2137 0%, #1A3A5C 50%, #162D1F 100%);
  }

  /* STAGES SCREEN */
  #stagesScreen {
    background: linear-gradient(160deg, #0D2137 0%, #1A3A5C 50%, #162D1F 100%);
  }

  .screen-header {
    width: 100%;
    max-width: 460px;
    display: flex;
    align-items: center;
    margin-bottom: 28px;
    gap: 12px;
  }

  .back-btn {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    color: white;
    font-size: 1.2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .back-btn:hover { background: rgba(255,255,255,0.2); }

  .screen-title {
    font-family: 'Amiri', serif;
    font-size: 1.5rem;
    color: var(--gold-light);
    font-weight: 700;
  }

  .level-cards {
    width: 100%;
    max-width: 460px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .level-card {
    border-radius: 20px;
    padding: 20px 22px;
    display: flex;
    align-items: center;
    gap: 16px;
    cursor: pointer;
    transition: all 0.25s ease;
    position: relative;
    overflow: hidden;
  }

  .level-card.unlocked {
    background: linear-gradient(135deg, rgba(45,106,79,0.5), rgba(26,58,92,0.5));
    border: 1.5px solid rgba(80,185,140,0.4);
  }

  .level-card.locked {
    background: rgba(255,255,255,0.04);
    border: 1.5px solid rgba(255,255,255,0.1);
    opacity: 0.6;
    cursor: not-allowed;
  }

  .level-card.unlocked:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(45,106,79,0.3);
    border-color: rgba(80,185,140,0.7);
  }

  .level-icon {
    width: 54px;
    height: 54px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    flex-shrink: 0;
  }

  .level-card.unlocked .level-icon {
    background: linear-gradient(135deg, var(--gold), var(--gold-dark));
  }

  .level-card.locked .level-icon {
    background: rgba(255,255,255,0.08);
  }

  .level-info { flex: 1; }

  .level-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: white;
    margin-bottom: 3px;
  }

  .level-desc {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.55);
  }

  .lock-icon {
    font-size: 1.3rem;
    color: rgba(255,255,255,0.3);
  }

  /* Stage cards */
  .stage-cards {
    width: 100%;
    max-width: 460px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .stage-card {
    border-radius: 18px;
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 14px;
    cursor: pointer;
    transition: all 0.25s ease;
    position: relative;
  }

  .stage-card.available {
    background: linear-gradient(135deg, rgba(212,168,71,0.15), rgba(26,58,92,0.4));
    border: 1.5px solid rgba(212,168,71,0.35);
  }

  .stage-card.available:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 26px rgba(212,168,71,0.2);
    border-color: rgba(212,168,71,0.6);
  }

  .stage-card.completed {
    background: linear-gradient(135deg, rgba(45,106,79,0.3), rgba(26,58,92,0.4));
    border: 1.5px solid rgba(80,185,140,0.4);
  }

  .stage-card.locked {
    background: rgba(255,255,255,0.03);
    border: 1.5px solid rgba(255,255,255,0.08);
    opacity: 0.5;
    cursor: not-allowed;
  }

  .stage-num {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--gold), var(--gold-dark));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--brown);
    flex-shrink: 0;
  }

  .stage-card.locked .stage-num {
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.3);
  }

  .stage-info { flex: 1; }

  .stage-name {
    font-size: 1rem;
    font-weight: 700;
    color: white;
    margin-bottom: 4px;
  }

  .stage-stars {
    display: flex;
    gap: 3px;
    direction: ltr;
  }

  .stage-star {
    font-size: 1rem;
    color: rgba(255,255,255,0.2);
  }

  .stage-star.filled { color: var(--star-yellow); }

  /* STORY SCREEN */
  #storyScreen {
    background: var(--cream);
    justify-content: flex-start;
    padding-top: 0;
  }

  .story-header {
    width: 100%;
    background: linear-gradient(135deg, var(--sky) 0%, var(--green) 100%);
    padding: 22px 20px 28px;
    position: relative;
    overflow: hidden;
  }

  .story-header::after {
    content: '';
    position: absolute;
    bottom: -15px;
    left: 0; right: 0;
    height: 30px;
    background: var(--cream);
    border-radius: 50% 50% 0 0;
  }

  .story-header-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .story-title-area { flex: 1; }

  .stage-label {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.6);
    font-weight: 500;
    margin-bottom: 3px;
    letter-spacing: 0.05em;
  }

  .story-title {
    font-family: 'Amiri', serif;
    font-size: 1.55rem;
    color: white;
    font-weight: 700;
    line-height: 1.2;
  }

  .story-body {
    flex: 1;
    overflow-y: auto;
    padding: 24px 20px;
    max-width: 540px;
    width: 100%;
    margin: 0 auto;
  }

  .story-text {
    font-size: 1.05rem;
    color: var(--brown);
    line-height: 2;
    font-weight: 400;
  }

  .story-text p {
    margin-bottom: 16px;
  }

  .story-footer {
    width: 100%;
    padding: 16px 20px 24px;
    background: var(--cream);
    border-top: 1px solid rgba(0,0,0,0.08);
    max-width: 540px;
    margin: 0 auto;
  }

  .btn-gold {
    display: block;
    width: 100%;
    padding: 16px;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
    color: var(--brown);
    font-family: 'Tajawal', sans-serif;
    font-size: 1.1rem;
    font-weight: 800;
    border: none;
    border-radius: 14px;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(212,168,71,0.35);
    transition: all 0.2s;
  }

  .btn-gold:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(212,168,71,0.4);
  }

  /* QUESTION SCREEN */
  #questionScreen {
    background: var(--cream);
    justify-content: flex-start;
    padding: 0;
  }

  .question-header {
    width: 100%;
    background: linear-gradient(135deg, var(--sky), var(--sky-light));
    padding: 18px 20px 22px;
    position: relative;
  }

  .question-header::after {
    content: '';
    position: absolute;
    bottom: -14px;
    left: 0; right: 0;
    height: 28px;
    background: var(--cream);
    border-radius: 50% 50% 0 0;
  }

  .q-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .q-counter {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    font-weight: 600;
  }

  .q-score {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.15);
    border-radius: 20px;
    padding: 5px 12px;
  }

  .q-score-icon { font-size: 0.9rem; }

  .q-score-val {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--gold-light);
  }

  .progress-bar {
    width: 100%;
    height: 6px;
    background: rgba(255,255,255,0.15);
    border-radius: 10px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold-light), var(--gold));
    border-radius: 10px;
    transition: width 0.4s ease;
  }

  .question-body {
    flex: 1;
    overflow-y: auto;
    padding: 28px 20px 16px;
    max-width: 540px;
    width: 100%;
    margin: 0 auto;
  }

  .q-text {
    font-family: 'Amiri', serif;
    font-size: 1.3rem;
    color: var(--sky);
    font-weight: 700;
    line-height: 1.6;
    margin-bottom: 24px;
    text-align: center;
  }

  .choices {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .choice-btn {
    padding: 14px 18px;
    background: white;
    border: 2px solid rgba(26,58,92,0.12);
    border-radius: 14px;
    font-family: 'Tajawal', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: var(--brown);
    cursor: pointer;
    text-align: right;
    transition: all 0.2s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    position: relative;
  }

  .choice-btn:hover:not(.disabled) {
    border-color: var(--gold);
    background: rgba(212,168,71,0.06);
    transform: translateX(-3px);
  }

  .choice-btn.correct {
    background: linear-gradient(135deg, rgba(39,174,96,0.12), rgba(39,174,96,0.05));
    border-color: var(--success);
    color: var(--success);
    font-weight: 700;
  }

  .choice-btn.wrong {
    background: linear-gradient(135deg, rgba(192,57,43,0.1), rgba(192,57,43,0.04));
    border-color: var(--error);
    color: var(--error);
    text-decoration: line-through;
  }

  .choice-btn.disabled { cursor: not-allowed; }

  .feedback-box {
    margin-top: 18px;
    padding: 14px 16px;
    border-radius: 14px;
    display: none;
    animation: slideIn 0.3s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .feedback-box.show { display: block; }

  .feedback-box.correct-fb {
    background: rgba(39,174,96,0.1);
    border: 1.5px solid rgba(39,174,96,0.3);
  }

  .feedback-box.wrong-fb {
    background: rgba(192,57,43,0.08);
    border: 1.5px solid rgba(192,57,43,0.25);
  }

  .fb-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .fb-icon { font-size: 1.2rem; }

  .fb-title {
    font-size: 0.95rem;
    font-weight: 700;
  }

  .correct-fb .fb-title { color: var(--success); }
  .wrong-fb .fb-title { color: var(--error); }

  .fb-text {
    font-size: 0.9rem;
    color: var(--brown-light);
    line-height: 1.7;
  }

  .question-footer {
    width: 100%;
    padding: 12px 20px 24px;
    background: var(--cream);
    border-top: 1px solid rgba(0,0,0,0.06);
    max-width: 540px;
    margin: 0 auto;
  }

  /* RESULT SCREEN */
  #resultScreen {
    background: linear-gradient(160deg, #0D2137 0%, #1A3A5C 40%, #0D3320 100%);
  }

  .result-card {
    background: rgba(255,255,255,0.05);
    border: 1.5px solid rgba(255,255,255,0.12);
    border-radius: 28px;
    padding: 32px 28px;
    max-width: 400px;
    width: 100%;
    text-align: center;
    backdrop-filter: blur(12px);
    animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }

  @keyframes popIn {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }

  .result-emoji {
    font-size: 4.5rem;
    margin-bottom: 12px;
    display: block;
    animation: bounce 0.6s ease 0.3s both;
  }

  @keyframes bounce {
    0% { transform: scale(0); }
    60% { transform: scale(1.1); }
    100% { transform: scale(1); }
  }

  .result-title {
    font-family: 'Amiri', serif;
    font-size: 1.8rem;
    color: var(--gold-light);
    font-weight: 700;
    margin-bottom: 6px;
  }

  .result-subtitle {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.55);
    margin-bottom: 24px;
  }

  .stars-row {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 24px;
    direction: ltr;
  }

  .big-star {
    font-size: 2.8rem;
    color: rgba(255,255,255,0.15);
    transition: all 0.3s ease;
  }

  .big-star.lit {
    color: var(--star-yellow);
    filter: drop-shadow(0 0 10px rgba(255,215,0,0.6));
    animation: starPop 0.4s ease both;
  }

  @keyframes starPop {
    0% { transform: scale(0) rotate(-30deg); }
    70% { transform: scale(1.2) rotate(10deg); }
    100% { transform: scale(1) rotate(0); }
  }

  .score-display {
    background: rgba(255,255,255,0.06);
    border-radius: 16px;
    padding: 16px;
    margin-bottom: 22px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .score-item { text-align: center; }

  .score-val {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--gold-light);
    display: block;
    line-height: 1;
    margin-bottom: 4px;
  }

  .score-label {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    font-weight: 500;
  }

  .result-buttons {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* ACHIEVEMENTS SCREEN */
  #achievementsScreen {
    background: linear-gradient(160deg, #0D2137 0%, #1A3A5C 50%, #162D1F 100%);
  }

  .achievements-grid {
    width: 100%;
    max-width: 460px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .achievement-card {
    background: rgba(255,255,255,0.06);
    border: 1.5px solid rgba(255,255,255,0.1);
    border-radius: 18px;
    padding: 16px 14px;
    text-align: center;
    transition: all 0.2s;
  }

  .achievement-card.earned {
    background: linear-gradient(135deg, rgba(212,168,71,0.15), rgba(26,58,92,0.3));
    border-color: rgba(212,168,71,0.4);
  }

  .ach-icon { font-size: 2.2rem; margin-bottom: 8px; }
  .ach-name { font-size: 0.85rem; font-weight: 700; color: white; margin-bottom: 4px; }
  .ach-desc { font-size: 0.73rem; color: rgba(255,255,255,0.45); line-height: 1.4; }
  .achievement-card:not(.earned) .ach-icon { filter: grayscale(1) opacity(0.3); }
  .achievement-card:not(.earned) .ach-name { color: rgba(255,255,255,0.35); }

  .total-stats {
    width: 100%;
    max-width: 460px;
    background: rgba(255,255,255,0.05);
    border: 1.5px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 18px 20px;
    margin-bottom: 20px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    text-align: center;
  }

  .stat-val {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--gold-light);
    display: block;
  }

  .stat-label {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.45);
  }

  /* ABOUT SCREEN */
  #aboutScreen {
    background: linear-gradient(160deg, #0D2137 0%, #1A3A5C 50%, #162D1F 100%);
  }

  .about-card {
    max-width: 420px;
    width: 100%;
    text-align: center;
    animation: fadeInUp 0.5s ease;
  }

  .about-icon { font-size: 3.5rem; margin-bottom: 14px; }

  .about-title {
    font-family: 'Amiri', serif;
    font-size: 1.6rem;
    color: var(--gold-light);
    margin-bottom: 10px;
  }

  .about-text {
    font-size: 0.92rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.9;
    margin-bottom: 20px;
  }

  .about-text strong { color: var(--gold-light); }

  .about-divider {
    width: 60px;
    height: 3px;
    background: var(--gold);
    margin: 20px auto;
    border-radius: 4px;
  }

  /* Scroll styling */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(212,168,71,0.3); border-radius: 4px; }
</style>
